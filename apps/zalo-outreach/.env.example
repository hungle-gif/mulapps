# ============================================
# Zalo Outreach — Environment Variables
# ============================================
# Copy file này thành .env và điền giá trị thật

# Database
DATABASE_URL="file:./dev.db"
# Production: DATABASE_URL="postgresql://user:password@host:5432/zalo_outreach"

# Redis (cho BullMQ job queue)
REDIS_URL="redis://localhost:6379"

# Encryption key cho credentials Zalo (generate: openssl rand -hex 32)
CREDENTIALS_ENCRYPTION_KEY="generate-a-64-char-hex-string-here"

# App
PORT=3010
NODE_ENV="development"
NEXT_PUBLIC_APP_URL="http://localhost:3010"

# Hub Integration
HUB_URL="http://localhost:3000"
HUB_TOKEN=""
APP_TOKEN=""
WEBHOOK_SECRET=""

# Safety Settings
DEFAULT_DELAY_MIN=30
DEFAULT_DELAY_MAX=120
DEFAULT_MAX_PER_DAY=50
SAFETY_MODE="normal"
# conservative — Extra delay, lower limits
# normal       — Balanced
# aggressive   — Shorter delay, higher limits (higher ban risk)
